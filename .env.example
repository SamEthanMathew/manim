# ============================================
# Manim — environment variables
# Copy to .env.local (Vercel) or use `modal secret`
# ============================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# --- Modal ---
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
MODAL_ENVIRONMENT=dev

# --- BYOK encryption key (server-side AES-GCM) ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
BYOK_ENCRYPTION_KEY=

# --- Observability ---
SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=manim-dev

# --- Dev-only LLM keys (NOT used for user jobs — BYOK only) ---
# These are for: corpus annotation, internal evals, dev scripts.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# --- App config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
